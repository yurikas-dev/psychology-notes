---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { useTranslations, type Lang } from '../i18n/translations';

interface Props {
  lang: Lang;
  section: 'positive' | 'performance';
}

const { lang, section } = Astro.props;
const t = useTranslations(lang);

const collectionName = lang === 'ja'
  ? `ja-${section}` as 'ja-positive' | 'ja-performance'
  : section;

const articles = await getCollection(collectionName);
articles.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const isPositive = section === 'positive';
const basePath = lang === 'ja' ? `/ja/${section}` : `/${section}`;

const bannerColors = isPositive
  ? ['from-emerald-200 to-teal-300', 'from-teal-200 to-emerald-300', 'from-green-200 to-teal-200', 'from-emerald-100 to-green-300']
  : ['from-violet-200 to-indigo-300', 'from-indigo-200 to-violet-300', 'from-purple-100 to-indigo-200', 'from-violet-100 to-purple-300'];

const badgeClass = isPositive ? 'badge-secondary' : 'badge-primary';
---

<Layout title={t(`${section}.title`)}>
  <div class="mb-10">
    <h1 class="text-3xl font-bold mb-2">{t(`${section}.title`)}</h1>
    <p class="text-base-content/60">{t(`${section}.description`)}</p>
  </div>

  {articles.length === 0 ? (
    <p class="text-base-content/40 text-sm">
      {lang === 'ja' ? '記事は準備中です。' : 'No articles yet. Check back soon.'}
    </p>
  ) : (
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {articles.map((article, i) => (
        <a href={`${basePath}/${article.id}`} class="card bg-base-100 shadow hover:shadow-lg transition-shadow overflow-hidden">
          {article.data.image
            ? <figure class="h-36 overflow-hidden"><img src={article.data.image} alt={article.data.title} class="w-full h-full object-cover" /></figure>
            : <figure class={`h-36 bg-gradient-to-br ${bannerColors[i % bannerColors.length]}`} />
          }
          <div class="card-body p-5">
            <h2 class="card-title text-base leading-snug">{article.data.title}</h2>
            <p class="text-sm text-base-content/60 mt-1 line-clamp-2">{article.data.description}</p>
            <div class="mt-3 flex items-center justify-between">
              <time class="text-xs text-base-content/40">{article.data.date}</time>
              {article.data.tags && article.data.tags.length > 0 && (
                <span class={`badge ${badgeClass} badge-outline badge-xs`}>{article.data.tags[0]}</span>
              )}
            </div>
          </div>
        </a>
      ))}
    </div>
  )}
</Layout>
