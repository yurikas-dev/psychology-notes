---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('performance');
articles.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const bannerColors = [
  'from-violet-200 to-indigo-300',
  'from-indigo-200 to-violet-300',
  'from-purple-100 to-indigo-200',
  'from-violet-100 to-purple-300',
];
---

<Layout title="Performance Psychology">
  <div class="mb-10">
    <h1 class="text-3xl font-bold mb-2">Performance Psychology</h1>
    <p class="text-base-content/60">Study notes on motivation, focus, goal-setting, and optimizing performance under pressure.</p>
  </div>

  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
    {articles.map((article, i) => (
      <a href={`/performance/${article.id}`} class="card bg-base-100 shadow hover:shadow-lg transition-shadow overflow-hidden">
        <figure class={`h-36 bg-gradient-to-br ${bannerColors[i % bannerColors.length]}`} />
        <div class="card-body p-5">
          <h2 class="card-title text-base leading-snug">{article.data.title}</h2>
          <p class="text-sm text-base-content/60 mt-1 line-clamp-2">{article.data.description}</p>
          <div class="mt-3 flex items-center justify-between">
            <time class="text-xs text-base-content/40">{article.data.date}</time>
            {article.data.tags && article.data.tags.length > 0 && (
              <span class="badge badge-primary badge-outline badge-xs">{article.data.tags[0]}</span>
            )}
          </div>
        </div>
      </a>
    ))}
  </div>
</Layout>
