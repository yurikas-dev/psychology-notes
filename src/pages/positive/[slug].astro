---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('positive');
  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);
---

<Layout title={article.data.title} description={article.data.description}>
  <div class="mb-6">
    <a href="/positive" class="btn btn-ghost btn-sm gap-1 -ml-2">
      ← Back to Positive Psychology
    </a>
  </div>

  <div class="card bg-base-100 shadow">
    <figure class="h-48 bg-gradient-to-br from-emerald-200 to-teal-300" />
    <div class="card-body">
      <div class="badge badge-secondary badge-sm mb-1">Positive Psychology</div>
      <h1 class="text-2xl font-bold">{article.data.title}</h1>
      <div class="flex items-center gap-3 mt-1 mb-4">
        <time class="text-sm text-base-content/40">{article.data.date}</time>
        {article.data.tags && (
          <div class="flex gap-2">
            {article.data.tags.map((tag) => (
              <span class="badge badge-secondary badge-outline badge-sm">{tag}</span>
            ))}
          </div>
        )}
      </div>
      <div class="divider mt-0 mb-4" />
      <article class="prose prose-sm max-w-none">
        <Content />
      </article>
    </div>
  </div>
</Layout>
