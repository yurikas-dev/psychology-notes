---
import '../styles/global.css'
import { getLangFromUrl, useTranslations, languages } from '../i18n/translations';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const currentPath = Astro.url.pathname;

const defaultDescription = 'Study notes on Positive Psychology and Performance Psychology';

// 言語切替URL: /ja/... ↔ /...
function getAlternatePath(currentPath: string, currentLang: string): string {
  if (currentLang === 'ja') {
    return currentPath.replace(/^\/ja/, '') || '/';
  } else {
    return '/ja' + (currentPath === '/' ? '' : currentPath);
  }
}
const alternateLang = lang === 'en' ? 'ja' : 'en';
const alternatePath = getAlternatePath(currentPath, lang);

// nav active判定
function isActive(path: string): boolean {
  const prefix = lang === 'ja' ? '/ja' : '';
  return currentPath.startsWith(`${prefix}/${path}`);
}
---

<html lang={lang} data-theme="nord">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description ?? defaultDescription} />
    <title>{title} | Psychology Notes</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Lora:ital,wght@0,600;0,700;1,600&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen bg-base-200 flex flex-col overflow-x-hidden">

    {(currentPath === '/' || currentPath === '/ja' || currentPath === '/ja/') && (
      <a
        href={alternatePath}
        class="fixed top-4 right-4 z-50 btn btn-sm bg-base-100/70 backdrop-blur-sm border border-base-300 hover:bg-base-100 font-medium text-xs"
      >
        {languages[alternateLang]}
      </a>
    )}

    {currentPath !== '/' && currentPath !== '/ja' && currentPath !== '/ja/' && (
    <div class="navbar bg-base-100 shadow-sm sticky top-0 z-10">
      <div class="w-full max-w-5xl mx-auto px-4 flex items-center">
        <div class="navbar-start">
          <a href={lang === 'ja' ? '/ja' : '/'} class="btn btn-ghost text-lg font-bold gap-2">
            <img src="/favicon.svg" alt="Psychology Notes logo" class="w-6 h-6" />
            Psychology Notes
          </a>
        </div>
        <div class="navbar-end hidden sm:flex items-center gap-2">
          <ul class="menu menu-horizontal px-1 gap-1">
            <li>
              <a href={lang === 'ja' ? '/ja/positive' : '/positive'}
                 class={isActive('positive') ? 'active' : ''}>
                {t('nav.positive')}
              </a>
            </li>
            <li>
              <a href={lang === 'ja' ? '/ja/performance' : '/performance'}
                 class={isActive('performance') ? 'active' : ''}>
                {t('nav.performance')}
              </a>
            </li>
          </ul>
          <a href={alternatePath} class="btn btn-ghost btn-sm font-medium opacity-50 hover:opacity-100">
            {languages[alternateLang]}
          </a>
        </div>
        <div class="navbar-end sm:hidden">
          <a href={alternatePath} class="btn btn-ghost btn-sm font-medium opacity-50 hover:opacity-100 mr-1">
            {languages[alternateLang]}
          </a>
          <div class="dropdown dropdown-end">
            <div tabindex="0" role="button" class="btn btn-ghost btn-square">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 20h16" />
              </svg>
            </div>
            <ul tabindex="0" class="menu menu-sm dropdown-content bg-base-100 rounded-box z-[1] mt-3 w-52 p-2 shadow">
              <li><a href={lang === 'ja' ? '/ja/positive' : '/positive'}>{t('nav.positive')}</a></li>
              <li><a href={lang === 'ja' ? '/ja/performance' : '/performance'}>{t('nav.performance')}</a></li>
            </ul>
          </div>
        </div>
      </div>
    </div>
    )}

    <main class="w-full max-w-5xl mx-auto px-4 py-10 flex-1">
      <slot />
    </main>

    <footer class="footer footer-center bg-base-100 text-base-content p-6 border-t border-base-300">
      <p class="text-sm opacity-60">Psychology Notes — {t('footer.text')}</p>
    </footer>

  </body>
</html>
